ANTHROPIC_API_KEY=your_api_key_here
MODEL=claude-sonnet-4-6
MAX_TOKENS=4096

# ── DrewAI Image Generation ───────────────────────────────────────
# Pollinations.ai is active by default (FREE, no key needed).
# Add one or more of the following to unlock more options:

# Hugging Face — FREE with a free account (best free quality)
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# fal.ai FLUX.1 — very cheap (~$0.003/image) | pip install fal-client
# Get key at: https://fal.ai
# FLUX_API_KEY=your_fal_api_key_here

# OpenAI DALL-E 3 — paid (~$0.04/image) | pip install openai
# DALLE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
